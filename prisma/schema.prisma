generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model Url {
    id          Int      @id @default(autoincrement())
    url         String
    shortCode   String   @unique
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    accessCount Int      @default(0)
}
